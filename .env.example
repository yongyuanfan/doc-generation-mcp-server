HTTP_ADDR=:9103
API_PREFIX=/api/v1
MCP_PATH=/mcp
REQUEST_TIMEOUT_SECONDS=120
MCP_SERVER_NAME=docx-generation-server
MCP_SERVER_VERSION=0.1.0
DOCX_TEMP_DIR=
DOCX_TEMPLATE_DIR=./templates
DOCX_DEFAULT_AUTHOR=doc-generation-mcp-server
DOCX_DEFAULT_FONT=Calibri
DOCX_DEFAULT_FONT_SIZE=22
DOCX_MAX_REQUEST_BODY_BYTES=2097152
DOCX_MAX_FILE_AGE_MINUTES=60
DOCX_DOCUMENT_TYPE_TEMPLATES=business_letter=business-letter.docx

# MinIO 配置（可选）
# 如果不配置或部分配置，将跳过 MinIO 上传，文件仅保存在本地
# MINIO_ENDPOINT=192.168.2.161:9000
# MINIO_ACCESS_KEY=your-access-key
# MINIO_SECRET_KEY=your-secret-key
# MINIO_BUCKET=docs-bucket
# MINIO_USE_SSL=false
# MINIO_PUBLIC_BASE_URL=http://192.168.2.161:9000
# MINIO_OBJECT_PREFIX=documents
# MINIO_AUTO_CREATE_BUCKET=false
